generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@spled/prisma-ghost"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum InactivityLevel {
  ACTIVE
  WARNING
  FLAGGED
}

model GhostBusterFlag {
  id              String   @id @default(uuid())
  projectId       String
  memberId        String
  level           InactivityLevel @default(ACTIVE)
  lastActivityAt  DateTime?
  noUpdateDays    Int      @default(0)
  flaggedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, memberId])
  @@index([projectId])
  @@index([memberId])
}