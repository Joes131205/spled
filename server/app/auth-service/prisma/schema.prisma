generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@spled/prisma-auth"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  username             String    @unique
  email                String    @unique
  password             String?
  role                 Role      @default(MEMBER)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lecturerAccessCode   String?   @unique
  lecturerAccessExpiry DateTime?
  avatarUrl            String?   @db.LongText
  displayName          String?
  googleId             String?   @unique
}

model LecturerAccessToken {
  id        String   @id @default(uuid())
  projectId String   @unique
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

enum Role {
  LEADER
  MEMBER
  LECTURER
}
