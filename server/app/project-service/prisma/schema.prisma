generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "mysql"
}

enum TaskWeight {
  EASY
  MEDIUM
  HARD
}

model Project {
  id          String     @id @default(uuid())
  name          String     @id @default(uuid())

}

model Task {
  id          String     @id @default(uuid())
  projectId   String
  name        String
  weight      TaskWeight @default(MEDIUM)
  progress    Float        @default(0) 
  assignedTo  String? 
}
